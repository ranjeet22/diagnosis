# ==========================================
# Diagnōsis - Environment Configuration
# ==========================================

# Application Settings
APP_NAME="Diagnōsis"
APP_ENV=development # development, staging, production
APP_VERSION="0.1.0"
DEBUG=true
PORT=8000
HOST="0.0.0.0"

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# Central Logging Configuration
LOG_LEVEL=info # debug, info, warning, error, critical
LOG_FILE_PATH="logs/app.log"
LOG_FORMAT="json" # text, json

# Storage Settings
STORAGE_TYPE=local # local, gcs
STORAGE_LOCAL_DIR="storage/uploads"
STORAGE_MAX_FILE_SIZE_MB=50

# Google Cloud Configuration (Future)
GCP_PROJECT_ID=""
GCP_SERVICE_ACCOUNT_KEY_JSON=""

# Google Cloud Storage (Future)
GCS_BUCKET_NAME=""

# Google BigQuery (Future)
BQ_DATASET_ID=""

# Gemini API Integration (Future)
GEMINI_API_KEY=""
GEMINI_MODEL_NAME="gemini-1.5-pro"

# Hardware / Acceleration Settings
GPU_ENABLED=false # cuDF vs. pandas fallback

# Future Authentication Configuration
JWT_SECRET=""
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
